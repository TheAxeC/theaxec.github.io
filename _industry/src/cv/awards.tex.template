\cvsection{{% emit(data['awards']['title']) %}}
\begin{cvhonors}
{%
  for i in data['awards']['content']:
    if compact and (i.get('compact') is False): continue
    emit_tex('\\cvhonor ')
    emit_braces(i['award'])
    emit_braces(i['event'])
    emit_braces(i.get('location', ''))
    emit_braces(i['date'])
%}
\end{cvhonors}
