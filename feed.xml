---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.data.website.header.intro }} - Research Diary</title>
  <subtitle>{{ site.data.website.research.title }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/blog' | absolute_url }}" rel="alternate" type="text/html"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/blog' | absolute_url }}</id>
  <author><name>{{ site.data.website.description.title }}</name></author>
  {% assign posts = site.blog | where: "publish", true | sort: 'date' | reverse %}
  {% for post in posts %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html"/>
    <id>{{ post.url | absolute_url }}</id>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    {% if post.category %}<category term="{{ post.category | xml_escape }}"/>{% endif %}
    <summary>{{ post.excerpt | strip_html | strip_newlines | xml_escape }}</summary>
    <content type="html">{{ post.content | xml_escape }}</content>
  </entry>
  {% endfor %}
</feed>
